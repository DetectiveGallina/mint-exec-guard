msgstr "Steam இல் %s கிடைக்கிறது"

#: .././mint_exec_guard/exec_guard.py:151
#, fuzzy, python-format
msgid "%s is already installed"
msgstr "%s ஏற்கனவே நிறுவப்பட்டுள்ளது"

#: .././mint_exec_guard/exec_guard.py:153
#, fuzzy, python-format

msgstr "லினக்ஸ் பயன்பாடுகள் நிறுவவும்"

#: .././desktop/com.mint.exec-guard.windows.desktop.in.h:1
msgid "Install Windows Application"
msgstr "விண்டோஸ் பயன்பாடு நிறுவவும்"

#: .././desktop/com.mint.exec-guard.windows.desktop.in.h:2
msgid "Install Windows Applications"
msgstr "விண்டோஸ் பயன்பாடு நிறுவவும்"

#: .././bin/mint-exec-guard-linux:32 .././bin/mint-exec-guard-windows:84
msgid "Run anyway"
msgstr "எவ்வகையிலேனும் ஐ இயக்கவும்"

#: .././bin/mint-exec-guard-windows:60
#, c-format
msgid "Install Windows App Support to run %s?"
msgstr "%s ஐ இயக்க விண்டோஸ் பயன்பாடு ஆதரவு நிறுவவும்?"

#: .././bin/mint-exec-guard-windows:69
#, c-format
msgid "%s is an unknown Windows app."
msgstr "%s அறியப்படாத விண்டோஸ் பயன்பாடாகும்."

#: .././bin/mint-exec-guard-windows:69
msgid "Some Windows apps may not be compatible with Windows App Support."
msgstr "சில விண்டோஸ் செயலிகள் விண்டோஸ் செயலி உதவிக்கு ஒத்துழைக்காமல் இருக்கலாம்."

#: .././bin/mint-exec-guard-windows:78
msgid "Is this a video game?"
msgstr "இது வீடியோ கேமா?"

#: .././bin/mint-exec-guard-windows:88
msgid "Install Windows App Support"
msgstr "Windows App ஆதரவு நிறுவவும்"


#: .././mint_exec_guard/exec_guard.py:140
#, python-format
msgid "Are you sure you want to run %s?"
msgstr "Jste si jistí, že chcete spustit %s?"

#: .././mint_exec_guard/exec_guard.py:146
#, python-format
msgid "%s is available on Steam"
msgstr "%s je k dispozici na Steamu"

#: .././mint_exec_guard/exec_guard.py:151
#, python-format
msgid "%s is already installed"
msgstr "%s je již nainstalován"

#: .././mint_exec_guard/exec_guard.py:153
#, python-format
msgid "%s can be installed from Software"
msgstr "%s může být nainstalován ze Softwarového manageru"

#: .././mint_exec_guard/exec_guard.py:157
#, python-format
msgid "%s is an alternative to %s."
msgstr "%s je alternativou k %s."

#: .././mint_exec_guard/exec_guard.py:174
#, python-format
msgid "%s is an unknown package."
msgstr "%s je neznámým balíčkem."

#: .././mint_exec_guard/exec_guard.py:174 .././bin/mint-exec-guard-windows:69
msgid ""
"Your computer and personal data may be vulnerable to a breach when running "
"apps from unknown sources."
msgstr ""
"Spouštěním aplikací z neznámých zdrojů můžete ohrozit bezpečnost vašeho "
"počítače a vašich dat."

#: .././mint_exec_guard/exec_guard.py:205
#, python-format
msgid "Launch %s"
msgstr "Spustit %s"

#: .././mint_exec_guard/exec_guard.py:211
#, python-format
msgid "Install %s"
msgstr "Nainstalovat %s"

#: .././mint_exec_guard/exec_guard.py:352
#, python-format
msgid "%s has been installed"
msgstr "%s byl nainstalován"

#: .././desktop/com.mint.exec-guard.linux.desktop.in.h:1
msgid "Install Linux Application"
msgstr "Nainstalovat Linuxovou aplikaci"

#: .././desktop/com.mint.exec-guard.linux.desktop.in.h:2
msgid "Install Linux Applications"
msgstr "Nainstalovat Linuxové aplikace"

#: .././desktop/com.mint.exec-guard.windows.desktop.in.h:1
msgid "Install Windows Application"
msgstr "Nainstalovat aplikaci pro Windows"

#: .././desktop/com.mint.exec-guard.windows.desktop.in.h:2
msgid "Install Windows Applications"
msgstr "Nainstalovat aplikace pro Windows"

#: .././bin/mint-exec-guard-linux:32 .././bin/mint-exec-guard-windows:84
msgid "Run anyway"
msgstr "Přesto spustit"

#: .././bin/mint-exec-guard-windows:60
#, c-format
msgid "Install Windows App Support to run %s?"
msgstr "Nainstalovat podporu aplikací pro Windows, aby bylo možné spustit %s?"

#: .././bin/mint-exec-guard-windows:69
#, c-format
msgid "%s is an unknown Windows app."
msgstr "%s je neznáma aplikace pro Windows."

#: .././bin/mint-exec-guard-windows:69
msgid "Some Windows apps may not be compatible with Windows App Support."
msgstr ""
"Některé aplikace pro Windows mohou být nekompatibilní se systémem podpory "
"aplikací pro Windows."

#: .././bin/mint-exec-guard-windows:78
msgid "Is this a video game?"
msgstr "Je to videohra?"

#: .././bin/mint-exec-guard-windows:88
msgid "Install Windows App Support"
msgstr "Nainstalovat podporu aplikací pro Windows"


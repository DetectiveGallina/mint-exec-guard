#, python-format
msgid "Are you sure you want to run %s?"
msgstr "Você tem certeza de que deseja executar %s?"

#: .././mint_exec_guard/exec_guard.py:146
#, python-format
msgid "%s is available on Steam"
msgstr "%s está disponível na Steam"


#, python-format
msgid "Launch %s"
msgstr "Lançar %s"

#: .././mint_exec_guard/exec_guard.py:211
#, python-format
msgid "Install %s"
msgstr "Instalar %s"

#: .././mint_exec_guard/exec_guard.py:352
